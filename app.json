{
  "expo": {
    "name": "Yoke",
    "slug": "yoke",
    "scheme": "yoke",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Yoke.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Yoke.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yokefaith.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Yoke sends a daily reminder for your devotional and notifies you when friends react to or comment on your posts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Yoke.png",
        "backgroundColor": "#F5C842"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yokefaith.app"
    },
    "web": {
      "favicon": "./assets/Yoke.png"
    },
    "plugins": [
      "expo-router",
      ["expo-notifications", {
        "icon": "./assets/Yoke.png",
        "color": "#F5C842"
      }]
    ]
  }
}
