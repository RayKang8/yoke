{
  "expo": {
    "name": "Yoke",
    "slug": "yoke",
    "scheme": "yoke",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Yoke-Icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Yoke.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yokefaith.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Yoke sends a daily reminder for your devotional and notifies you when friends react to or comment on your posts.",
        "NSPhotoLibraryUsageDescription": "Yoke uses your photo library so you can set a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Yoke.png",
        "backgroundColor": "#F5C842"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yokefaith.app"
    },
    "web": {
      "favicon": "./assets/Yoke-Icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/Yoke-Icon.png",
          "color": "#F5C842"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b309bb9-d078-4507-bbd6-abb2dc61333c"
      }
    }
  }
}
